generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BarbecueEvent {
  id          String   @id @default(cuid())
  inviteCode  String   @unique
  name        String
  date        DateTime
  address     String
  organizerId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       Item[]

  @@index([organizerId])
}

model Item {
  id        String        @id @default(cuid())
  name      String
  bbqId     String
  bbq       BarbecueEvent @relation(fields: [bbqId], references: [id], onDelete: Cascade)
  claims    Claim[]
  createdAt DateTime      @default(now())

  @@index([bbqId])
}

model Claim {
  id        String   @id @default(cuid())
  guestName String
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([itemId])
}
